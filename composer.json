{
    "name": "hstanleycrow/corvagia",
    "description": "A modern and lightweight PHP framework designed for both full-stack MVC web applications and high-performance APIs.",
    "type": "project",
    "keywords": [
        "php",
        "framework",
        "mvc",
        "api",
        "rest-api",
        "corvagia",
        "backend"
    ],
    "license": "MIT",
    "homepage": "https://github.com/hstanleycrow/corvagia",
    "authors": [
        {
            "name": "Harold Rivas AKA Harold Crow",
            "email": "holamundo@microaplicaciones.com",
            "homepage": "https://www.microaplicaciones.com/",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "monolog/monolog": "^3.10",
        "league/plates": "^3.6",
        "altorouter/altorouter": "^2.0",
        "vlucas/phpdotenv": "^5.6",
        "fakerphp/faker": "^1.24",
        "symfony/http-foundation": "^6.3",
        "hstanleycrow/easyphpdbcore": "^1.0",
        "hstanleycrow/easyphpdatatablecrud": "^2.1.0",
        "hstanleycrow/easyphpdatatables": "^2.1.0",
        "hstanleycrow/easyphpformvalidator": "^2.1.0",
        "hstanleycrow/easyphpwebcomponents": "^1.1.0",
        "firebase/php-jwt": "^7.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Models\\": "app/Models/",
            "Config\\": "config/"
        },
        "files": [
            "helpers/helpers.php",
            "helpers/debug.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "App\\": "tests/Fixtures/App/",
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "allow-plugins": {
            "robloach/component-installer": true
        }
    }
}
